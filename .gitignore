# ─────────────────────────────────────────────────────────────────────────────
# TruthStream .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/

# ── Python ────────────────────────────────────────────────────────────────────
venv/
.venv/
*/venv/
*/.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg-info/

# ── Java / Maven ──────────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.mvn/repository/

# ── Environment / Secrets ─────────────────────────────────────────────────────
# .env contains real secrets — NEVER commit it.
# .env.example is safe and SHOULD be committed.
.env
.env.local
.env.*.local
# Note: .env.example is intentionally NOT listed here

# ── Docker ────────────────────────────────────────────────────────────────────
# Do not ignore docker-compose.yml, Dockerfiles, or .dockerignore files —
# these are infrastructure-as-code and must be committed.

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.iml
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?