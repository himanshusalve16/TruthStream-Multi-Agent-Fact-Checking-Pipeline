# ── Build outputs (Docker builds from source, not from pre-built artifacts) ───
target/

# ── Maven local repository (not needed in Docker context) ─────────────────────
.mvn/repository/

# ── Windows-only Maven wrapper (unnecessary in Linux containers) ───────────────
mvnw.cmd

# ── Editor / IDE files ────────────────────────────────────────────────────────
.idea/
*.iml
.settings/
.classpath
.project
.vscode/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Local env files (secrets must never be baked into the image) ──────────────
.env
.env.*
