# ─────────────────────────────────────────────────────────────────────────────
# TruthStream — Environment Variable Template
#
# USAGE:
#   1. Copy this file:  cp .env.example .env   (or: Copy-Item .env.example .env)
#   2. Fill in your real API keys and secrets
#   3. Run:            docker compose up --build
#
# This file is SAFE to commit — it contains NO real secrets.
# The .env file (with real values) is in .gitignore.
#
# HOW DOCKER USES THESE VARS:
#   Docker Compose reads .env and injects values into each service's environment.
#   Services communicate using Docker internal DNS names:
#     db, redis, backend, ai-service
#   NOT localhost. The *_PORT values below are host-side port mappings only.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_PORT: which port on YOUR MACHINE maps to the container's Postgres (5432).
# Change if port 5432 is already occupied locally (e.g., by a local Postgres install).
DB_PORT=5432
DB_NAME=truthstream
DB_USER=postgres
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PORT: which port on YOUR MACHINE maps to the container's Redis (6379).
REDIS_PORT=6379

# ── Service port mappings (host-side) ─────────────────────────────────────────
SPRING_PORT=8080
FASTAPI_PORT=8000
FRONTEND_PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-hex-char-secret-do-not-use-this-value
JWT_EXPIRY_MS=3600000

# ── External AI APIs ──────────────────────────────────────────────────────────
# REQUIRED: Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sk-replace-me

# OPTIONAL: SerpAPI improves web search quality (~100 free queries/month).
# If not set (or set to replace-me), search falls back to free DuckDuckGo.
# Get a key at https://serpapi.com
SERPAPI_KEY=replace-me

# ── Internal service auth ──────────────────────────────────────────────────────
# Spring Boot sends this header when calling FastAPI. Must match on both services.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(16))"
INTERNAL_API_SECRET=replace-with-random-32-char-hex-string
