# ─────────────────────────────────────────────────────────────────────────────
# TruthStream — Environment Variable Template
#
# USAGE:
#   1. Copy this file:  cp .env.example .env   (or: Copy-Item .env.example .env)
#   2. Fill in your real API keys and secrets
#   3. Run:            docker compose up --build
#
# This file is SAFE to commit — it contains NO real secrets.
# The .env file (with real values) is in .gitignore.
#
# HOW DOCKER USES THESE VARS:
#   Docker Compose reads .env and injects values into each service's environment.
#   Services communicate using Docker internal DNS names:
#     db, redis, backend, ai-service
#   NOT localhost. The *_PORT values below are host-side port mappings only.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_PORT: which port on YOUR MACHINE maps to the container's Postgres (5432).
# Change if port 5432 is already occupied locally (e.g., by a local Postgres install).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=truthstream
DB_USER=postgres
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PORT: which port on YOUR MACHINE maps to the container's Redis (6379).
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Service port mappings (host-side) ─────────────────────────────────────────
SPRING_PORT=8080
FASTAPI_PORT=8000
FRONTEND_PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-hex-char-secret-do-not-use-this-value
JWT_EXPIRY_MS=3600000

# ── External AI APIs ──────────────────────────────────────────────────────────
# REQUIRED: Get your key at https://aistudio.google.com/app/apikey
# Provide up to 4 API keys for automatic key rotation on quota exhaustion / failures
GEMINI_API_KEY_1=replace-me
GEMINI_API_KEY_2=replace-me
GEMINI_API_KEY_3=replace-me
GEMINI_API_KEY_4=replace-me
GEMINI_MODEL=gemini-2.5-flash-lite

# OPTIONAL: SerpAPI improves web search quality (~100 free queries/month).
# If not set (or set to replace-me), search falls back to free DuckDuckGo.
# Get a key at https://serpapi.com
SERPAPI_KEY=replace-me

# ── Internal service auth ──────────────────────────────────────────────────────
# Spring Boot sends this header when calling FastAPI. Must match on both services.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(16))"
INTERNAL_API_SECRET=replace-with-random-32-char-hex-string

# ── Eureka Service Discovery ───────────────────────────────────────────────────
# Eureka is the service registry that allows the gateway to discover the AI
# service dynamically instead of using a hardcoded URL.
#
# LOCAL (Docker Compose): Leave these commented out — Docker Compose sets them
# automatically via the environment block in docker-compose.yml.
#
# RENDER PRODUCTION: Uncomment and set these to your Render URLs.
#
# Render Eureka dashboard URL (after deploying truthstream-eureka):
# EUREKA_PORT=8761
#
# Gateway (Spring Boot): point at the deployed Eureka registry.
# Example: https://truthstream-eureka.onrender.com/eureka/
# EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=https://truthstream-eureka.onrender.com/eureka/
#
# Set to "true" to enable Eureka registration (defaults to "true" when URL is set).
# Set to "false" to run in static URL mode (no Eureka).
# EUREKA_CLIENT_ENABLED=true
#
# AI Service (FastAPI): point at the deployed Eureka registry.
# EUREKA_SERVER_URL=https://truthstream-eureka.onrender.com/eureka/
#
# Hostname the AI service advertises to Eureka.
# LOCAL: defaults to "ai-service" (Docker DNS name) — do not change.
# RENDER: set this to your AI service's Render hostname.
# Example: INSTANCE_HOST=ai-service-w29p.onrender.com
# INSTANCE_HOST=ai-service
#
# Port the AI service listens on internally (before Render TLS termination).
# INSTANCE_PORT=8000
