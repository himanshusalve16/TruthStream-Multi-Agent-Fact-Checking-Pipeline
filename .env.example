# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=truthstream
DB_USER=postgres
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Spring Boot
SPRING_PORT=8080
JWT_SECRET=replace-with-64-char-secret-do-not-use-this-in-production
JWT_EXPIRY_MS=3600000

# FastAPI
FASTAPI_PORT=8000
FASTAPI_BASE_URL=http://localhost:8000

# AI / External APIs
OPENAI_API_KEY=sk-replace-me
# Optional: SerpAPI improves source quality (~100 free searches/month at serpapi.com)
# If omitted or replace-me, search falls back to DuckDuckGo (free, no key)
SERPAPI_KEY=replace-me

# Internal auth (Spring Boot calls FastAPI with this header)
INTERNAL_API_SECRET=replace-with-random-32-char-string
